# NBA Charter Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

# Discord bot token (from discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# ID of the Discord channel to send notifications to
# Enable Developer Mode in Discord settings, then right-click a channel → Copy Channel ID
DISCORD_CHANNEL_ID=your_channel_id_here

# FlightRadar24 account credentials (free account at flightradar24.com)
# Required for reliable API access
FR24_USERNAME=your_fr24_email_here
FR24_PASSWORD=your_fr24_password_here
